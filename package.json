{
  "name": "whiteboard-desktop",
  "version": "1.0.0",
  "description": "Whiteboard Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:client": "cd Client && npm run build",
    "pack": "electron-builder --dir",
    "dist": "npm run build:client && electron-builder"
  },
  "build": {
    "appId": "com.proedu1.whiteboard",
    "productName": "ProEdu1",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "ProEdu1.exe"
    },
    "files": [
      "electron/**/*",
      "Server/**/*",
      "!Server/node_modules/**/*",
      "Client/dist/**/*",
      "package.json",
      ".env"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
